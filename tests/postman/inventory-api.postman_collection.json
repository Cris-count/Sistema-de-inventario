{
  "info": {
    "_postman_id": "inv-api-v3-paso8",
    "name": "Sistema Inventario API",
    "description": "PASO 8: ejecutar carpetas en orden (Auth → Setup → Errores → Flujos → roles). Variables: baseUrl, token (=ADMIN), tokenAdmin, tokenAux, tokenCompras, tokenGerencia, suf, categoriaId, bodegaId, bodegaId2, productoId, proveedorId. Newman: npm run test:api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "tokenAdmin", "value": "" },
    { "key": "tokenAux", "value": "" },
    { "key": "tokenCompras", "value": "" },
    { "key": "tokenGerencia", "value": "" },
    { "key": "suf", "value": "" },
    { "key": "categoriaId", "value": "" },
    { "key": "bodegaId", "value": "" },
    { "key": "bodegaId2", "value": "" },
    { "key": "productoId", "value": "" },
    { "key": "proveedorId", "value": "" }
  ],
  "item": [
    {
      "name": "1 Auth (semillas)",
      "item": [
        {
          "name": "Login ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.expect(j.accessToken).to.be.a('string');",
                  "pm.collectionVariables.set('token', j.accessToken);",
                  "pm.collectionVariables.set('tokenAdmin', j.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@inventario.local\",\n  \"password\": \"Admin123!\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login AUX_BODEGA",
          "event": [
            {

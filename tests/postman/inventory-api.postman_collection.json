{
  "info": {
    "_postman_id": "a1b2c3d4-inventario-api",
    "name": "Sistema Inventario API (PASO 4)",
    "description": "Pruebas de contrato para Spring Boot. Ajustar baseUrl al puerto real.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "productoId", "value": "1" },
    { "key": "bodegaId", "value": "1" },
    { "key": "bodegaId2", "value": "2" },
    { "key": "movimientoEntradaId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login correcto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "try { var j = pm.response.json(); if (j.accessToken) pm.collectionVariables.set('token', j.accessToken); } catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"cambiar\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login incorrecto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 o 400', function () { pm.expect([400,401]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"mala\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Catalogo",
      "item": [
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"SKU-001\",\n  \"nombre\": \"Producto demo\",\n  \"categoriaId\": 1,\n  \"unidadMedida\": \"UND\",\n  \"stockMinimo\": 5\n}"
            },
            "url": "{{baseUrl}}/productos"
          }
        },
        {
          "name": "Crear bodega",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"BOD-01\",\n  \"nombre\": \"Bodega central\"\n}"
            },
            "url": "{{baseUrl}}/bodegas"
          }
        }
      ]
    },
    {
      "name": "Movimientos",
      "item": [
        {
          "name": "Registrar entrada",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motivo\": \"COMPRA\",\n  \"proveedorId\": 1,\n  \"referenciaDocumento\": \"OC-100\",\n  \"lineas\": [\n    {\n      \"productoId\": {{productoId}},\n      \"bodegaDestinoId\": {{bodegaId}},\n      \"cantidad\": 100\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/movimientos/entradas"
          }
        },
        {
          "name": "Registrar salida con stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motivo\": \"VENTA\",\n  \"referenciaDocumento\": \"PED-1\",\n  \"lineas\": [\n    {\n      \"productoId\": {{productoId}},\n      \"bodegaOrigenId\": {{bodegaId}},\n      \"cantidad\": 10\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/movimientos/salidas"
          }
        },
        {
          "name": "Salida sin stock suficiente (esperado 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Conflicto negocio', function () { pm.expect([409,400]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motivo\": \"VENTA\",\n  \"lineas\": [\n    {\n      \"productoId\": {{productoId}},\n      \"bodegaOrigenId\": {{bodegaId}},\n      \"cantidad\": 999999\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/movimientos/salidas"
          }
        },
        {
          "name": "Transferencia entre bodegas",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenciaDocumento\": \"TR-1\",\n  \"lineas\": [\n    {\n      \"productoId\": {{productoId}},\n      \"bodegaOrigenId\": {{bodegaId}},\n      \"bodegaDestinoId\": {{bodegaId2}},\n      \"cantidad\": 5\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/movimientos/transferencias"
          }
        }
      ]
    },
    {
      "name": "Consultas",
      "item": [
        {
          "name": "Consulta inventario",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/inventario?bodegaId={{bodegaId}}&page=0&size=20"
          }
        }
      ]
    }
  ]
}

{
  "name": "inventario",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run frontend",
    "frontend": "node scripts/serve-frontend.mjs",
    "dev": "npm run frontend",
    "backend": "node scripts/run-backend.mjs",
    "db": "docker compose up -d db",
    "db:sync": "node scripts/db-sync-dev.mjs",
    "db:reset": "node scripts/reset-dev-db.mjs",
    "up": "node scripts/dev-up.mjs",
    "down": "node scripts/dev-down.mjs",
    "db:up": "docker compose up -d",
    "db:up:build": "docker compose up -d --build",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:api": "newman run tests/postman/inventory-api.postman_collection.json --delay-request 150 --timeout-request 30000",
    "ci": "npm run build && ng test --no-watch",
    "serve:ssr:Inventario": "node dist/Inventario/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/animations": "21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.3",
    "express": "^5.1.0",
    "gsap": "^3.15.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "newman": "^6.2.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}

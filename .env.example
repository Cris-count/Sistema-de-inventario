# Copiar a `.env` en la raíz del repo (opcional) para sobrescribir valores de docker compose.
# Ver README: sección Docker y variables del backend.
#
# No dejes líneas APP_SEED_* vacías: en algunos entornos Spring recibe "" y no se crean usuarios semilla
# (login falla con "Credenciales inválidas"). Omite la variable o pon un valor real.
# Valores por defecto del proyecto: aux@inventario.local / AuxBodega123!, etc.

JWT_SECRET=
# APP_SEED_ADMIN_EMAIL=
# APP_SEED_ADMIN_PASSWORD=
# APP_SEED_AUX_EMAIL=
# APP_SEED_AUX_PASSWORD=
# APP_SEED_COMPRAS_EMAIL=
# APP_SEED_COMPRAS_PASSWORD=
# APP_SEED_GERENCIA_EMAIL=
# APP_SEED_GERENCIA_PASSWORD=

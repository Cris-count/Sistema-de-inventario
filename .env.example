# Copiar a `.env` en la raiz del repo para sobrescribir valores locales de Docker y scripts.
# No incluir secretos reales en este archivo.

# PostgreSQL / Docker
POSTGRES_DB=inventario
POSTGRES_USER=inventario
POSTGRES_PASSWORD=inventario
DB_URL=jdbc:postgresql://localhost:5433/inventario
DB_USER=inventario
DB_PASSWORD=inventario

# Spring Boot
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# JWT / Auth
JWT_SECRET=cambiarEnProduccionMinimo256BitsParaHS256AlgoritmoSeguro!!
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Seed local opcional
APP_SEED_ADMIN_EMAIL=admin@inventario.local
APP_SEED_ADMIN_PASSWORD=Admin123!
APP_SEED_AUX_EMAIL=aux@inventario.local
APP_SEED_AUX_PASSWORD=AuxBodega123!
APP_SEED_COMPRAS_EMAIL=compras@inventario.local
APP_SEED_COMPRAS_PASSWORD=Compras123!
APP_SEED_GERENCIA_EMAIL=gerencia@inventario.local
APP_SEED_GERENCIA_PASSWORD=Gerencia123!

# Stripe (opcional en desarrollo)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# AI service
AI_SERVICE_URL=http://localhost:8000

# Mailpit / SMTP dev
MAIL_HOST=localhost
MAIL_PORT=1025

# Rate limiting / Redis
RATE_LIMIT_BACKEND=memory
REDIS_HOST=localhost
REDIS_PORT=6379

# Copie este archivo a application-local.yml (está en .gitignore) y rellene usuario/contraseña.
# Gmail: use una "contraseña de aplicación", no la clave normal.
#
# spring.mail.host vacío en el yml principal evita crear el cliente SMTP; aquí sí se define.

spring:
  mail:
    host: smtp.gmail.com
    port: 587
    username: CAMBIE_SU_CORREO@gmail.com
    password: CAMBIE_CONTRASENA_DE_APLICACION

# Opcional: forzar solo log sin intentar SMTP aunque haya host (útil para depurar)
# app:
#   inventory:
#     stock-alerts:
#       send-email: false
#
# Stripe (modo test): definir en el entorno del proceso, no en código.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...   # reservado (Checkout alojado no lo usa en el front)
# STRIPE_WEBHOOK_SECRET=whsec_...   # opcional: POST /api/v1/billing/stripe/webhook
